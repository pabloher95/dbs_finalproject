# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# When Supabase third-party auth is configured for Clerk, set this to your Clerk JWT template name (often "supabase").
# CLERK_JWT_TEMPLATE=supabase
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase (use the anon / publishable key only — not the service-role key)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local workspace owner used when Clerk is not wired or for seeded demo mode.
SMALLBIZ_OWNER_ID=owner_demo

# Optional: allow in-memory workspace fallback outside Supabase during local/dev work.
# Keep unset in production so auth/data failures do not silently switch persistence modes.
# SMALLBIZ_ALLOW_MEMORY_FALLBACK=true
